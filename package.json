{
  "name": "baykusbot",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready BaykusBot with TypeScript, Prisma, Redis and Discord.js",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:shard": "node dist/shard.js",
    "shard:dev": "tsx src/shard.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "deploy:commands:prod": "node dist/deploy-commands.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bullmq": "^5.76.5",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "ioredis": "^5.6.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
