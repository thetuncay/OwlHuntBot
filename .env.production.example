# VDS uretim sablonu — kopyala: cp .env.production.example .env
# Sonra DISCORD_TOKEN ve API anahtarlarini doldur.

DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# Docker icinde pgbouncer servisine baglanir (localhost DEGIL)
DATABASE_URL=postgresql://postgres@pgbouncer:5432/owlhuntbot?pgbouncer=true&connection_limit=200&pool_timeout=45&connect_timeout=15
REDIS_URL=redis://redis:6379
NODE_ENV=production

NODE_OPTIONS=--max-old-space-size=5120
UV_THREADPOOL_SIZE=24

DB_CONNECTION_LIMIT=200
DB_POOL_TIMEOUT_SEC=45
DB_QUEUE_CONCURRENCY=64
PLAYER_CACHE_TTL_S=120
MAINTENANCE_BATCH_SIZE=2000
REDIS_COMMAND_TIMEOUT_MS=10000

DISCORD_CACHE_MESSAGES=3000
DISCORD_CACHE_USERS=50000
DISCORD_CACHE_MEMBERS=10000
DISCORD_MSG_SWEEP_SEC=14400

GEMINI_API_KEY=
GROQ_API_KEY=
