generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Player {
  id                 String   @id @map("_id")
  coins              Int      @default(0)
  level              Int      @default(1)
  xp                 Int      @default(0)
  mainOwlId          String?
  lastHunt           DateTime?
  lastSwitch         DateTime?
  pvpStreak          Int      @default(0)
  pvpStreakLoss      Int      @default(0)
  gambleStreakWins   Int      @default(0)
  gambleStreakLosses Int      @default(0)
  huntComboStreak    Int      @default(0)
  pvpCount           Int      @default(0)
  switchPenaltyUntil DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // --- LIDERBOARD ISTATISTIKLERI ---
  totalHunts       Int      @default(0)   // Toplam basarili av sayisi
  totalRareFinds   Int      @default(0)   // Toplam Rare+ kalite esya/baykus bulma
  totalPvpWins     Int      @default(0)   // Toplam PvP galibiyeti
  totalCoinsEarned Int      @default(0)   // Toplam kazanilan coin (harcama sayilmaz)
  powerScore       Int      @default(0)   // Hesaplanmis guc skoru (cache)

  // --- PVP STREAK ---
  pvpBestStreak    Int      @default(0)   // Tum zamanlarin en yuksek streak'i

  // --- PITY SISTEMI ---
  noRareStreak     Int      @default(0)   // Kac hunt'tur nadir hayvan yakalanmadi

  // --- BUFF & LOOTBOX SISTEMI ---
  dailyLootboxDrops   Int       @default(0)   // Bugun kac lootbox drop aldi
  lastLootboxDropDate DateTime?               // Son lootbox drop tarihi (gunluk cap icin)

  // --- TRANSFER SİSTEMİ ---
  dailyTransferSent   Int       @default(0)   // Bugun gonderilen toplam coin
  lastTransferDate    DateTime?               // Son transfer tarihi (gunluk cap icin)

  owls            Owl[]
  inventory       InventoryItem[]
  pvpAsChallenger PvpSession[]   @relation("Challenger")
  pvpAsDefender   PvpSession[]   @relation("Defender")
  encounters      Encounter[]
  registrations   PlayerRegistration[]
  seasonArchives  SeasonArchive[]
  activeBuffs     PlayerBuff[]
}

// Aktif buff kayitlari — oyuncunun kullandigı geçici buff'lar
model PlayerBuff {
  id          String   @id @default(uuid()) @map("_id")
  playerId    String
  buffItemId  String   // BUFF_ITEMS[].id
  category    String   // 'hunt' | 'upgrade' | 'pvp'
  effectType  String   // 'catch_bonus' | 'loot_mult' | vb.
  effectValue Float
  chargeMax   Int      // Maksimum charge (item tanımından kopyalanır)
  chargeCur   Int      // Kalan charge (0 = pasif, item silinmez)
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, category])
  @@index([playerId, effectType])
}

// Sezon kayitlari — her sezon sonunda anlık snapshot
model SeasonArchive {
  id             String   @id @default(uuid()) @map("_id")
  playerId       String
  seasonId       String   // "2026-W16" veya "2026-04" formatinda
  seasonType     String   // "weekly" | "monthly"
  powerScore     Int      @default(0)
  totalHunts     Int      @default(0)
  totalRareFinds Int      @default(0)
  totalPvpWins   Int      @default(0)
  totalCoinsEarned Int    @default(0)
  rank           Int      @default(0)   // O sezon sonu sirasi
  archivedAt     DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([seasonId])
  @@index([playerId])
}

// Aktif sezon bilgisi (tek kayit, upsert ile guncellenir)
model Season {
  id         String   @id @map("_id")   // "current" sabit ID
  seasonId   String                      // "2026-W16"
  seasonType String                      // "weekly" | "monthly"
  startedAt  DateTime @default(now())
  endsAt     DateTime
}

model Owl {
  id            String   @id @default(uuid()) @map("_id")
  ownerId       String
  species       String
  tier          Int
  bond          Int      @default(0)
  passiveMode   String   @default("idle")
  statGaga      Int      @default(1)
  statGoz       Int      @default(1)
  statKulak     Int      @default(1)
  statKanat     Int      @default(1)
  statPence     Int      @default(1)
  quality       String   @default("Common")
  hp            Int
  hpMax         Int
  staminaCur    Int
  isMain        Boolean  @default(false)
  effectiveness Int      @default(100)
  createdAt     DateTime @default(now())
  // Trait sistemi: [{ id, bonus, penalty }] formatinda JSON dizi
  // Eski kayitlarda null gelir — sistem null'u gracefully handle eder
  traits        Json?

  owner Player @relation(fields: [ownerId], references: [id])
}

model InventoryItem {
  id       String @id @default(uuid()) @map("_id")
  ownerId  String
  itemName String
  itemType String
  rarity   String
  quantity Int    @default(1)

  owner Player @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, itemName])
}

model PvpSession {
  id           String   @id @default(uuid()) @map("_id")
  challengerId String
  defenderId   String
  status       String   @default("pending")
  winnerId     String?
  totalTurns   Int?
  createdAt    DateTime @default(now())
  finishedAt   DateTime?

  challenger Player @relation("Challenger", fields: [challengerId], references: [id])
  defender   Player @relation("Defender", fields: [defenderId], references: [id])
}

model Encounter {
  id           String   @id @default(uuid()) @map("_id")
  playerId     String
  owlSpecies   String
  owlTier      Int
  owlQuality   String
  owlStats     Json
  owlTraits    Json?    // Encounter sirasinda uretilen trait listesi
  tameAttempts Int      @default(0)
  failStreak   Int      @default(0)
  status       String   @default("open")
  createdAt    DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])
}

model PlayerRegistration {
  id          String   @id @default(uuid()) @map("_id")
  userId      String
  username    String
  displayName String?
  guildId     String
  guildName   String
  acceptedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player Player @relation(fields: [userId], references: [id])

  @@unique([userId, guildId])
  @@index([guildId])
}
