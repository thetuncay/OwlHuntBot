generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Player {
  id                 String   @id @map("_id")
  coins              Int      @default(0)
  level              Int      @default(1)
  xp                 Int      @default(0)
  mainOwlId          String?
  lastHunt           DateTime?
  lastSwitch         DateTime?
  pvpStreak          Int      @default(0)
  pvpStreakLoss      Int      @default(0)
  gambleStreakWins   Int      @default(0)
  gambleStreakLosses Int      @default(0)
  huntComboStreak    Int      @default(0)
  pvpCount           Int      @default(0)
  switchPenaltyUntil DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // --- LIDERBOARD ISTATISTIKLERI ---
  totalHunts       Int      @default(0)
  totalRareFinds   Int      @default(0)
  totalPvpWins     Int      @default(0)
  totalCoinsEarned Int      @default(0)
  powerScore       Int      @default(0)

  // --- PVP STREAK ---
  pvpBestStreak    Int      @default(0)

  // --- PITY SISTEMI ---
  noRareStreak     Int      @default(0)

  // --- BUFF & LOOTBOX SISTEMI ---
  dailyLootboxDrops   Int       @default(0)
  lastLootboxDropDate DateTime?

  // --- TRANSFER SİSTEMİ ---
  dailyTransferSent   Int       @default(0)
  lastTransferDate    DateTime?

  owls            Owl[]
  inventory       InventoryItem[]
  pvpAsChallenger PvpSession[]   @relation("Challenger")
  pvpAsDefender   PvpSession[]   @relation("Defender")
  encounters      Encounter[]
  registrations   PlayerRegistration[]
  seasonArchives  SeasonArchive[]
  activeBuffs     PlayerBuff[]

  // Liderboard sıralama index'leri — full table scan'i önler
  @@index([powerScore])
  @@index([totalHunts])
  @@index([totalRareFinds])
  @@index([totalPvpWins])
  @@index([totalCoinsEarned])
}

// Aktif buff kayitlari — oyuncunun kullandigı geçici buff'lar
model PlayerBuff {
  id          String   @id @default(uuid()) @map("_id")
  playerId    String
  buffItemId  String
  category    String
  effectType  String
  effectValue Float
  chargeMax   Int
  chargeCur   Int
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, category])
  @@index([playerId, effectType])
  // Aktif buff sorgusu için (chargeCur > 0 filtresi)
  @@index([playerId, category, chargeCur])
}

// Sezon kayitlari — her sezon sonunda anlık snapshot
model SeasonArchive {
  id             String   @id @default(uuid()) @map("_id")
  playerId       String
  seasonId       String   // "2026-W16" veya "2026-04" formatinda
  seasonType     String   // "weekly" | "monthly"
  powerScore     Int      @default(0)
  totalHunts     Int      @default(0)
  totalRareFinds Int      @default(0)
  totalPvpWins   Int      @default(0)
  totalCoinsEarned Int    @default(0)
  rank           Int      @default(0)   // O sezon sonu sirasi
  archivedAt     DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([seasonId])
  @@index([playerId])
}

// Aktif sezon bilgisi (tek kayit, upsert ile guncellenir)
model Season {
  id         String   @id @map("_id")   // "current" sabit ID
  seasonId   String                      // "2026-W16"
  seasonType String                      // "weekly" | "monthly"
  startedAt  DateTime @default(now())
  endsAt     DateTime
}

model Owl {
  id            String   @id @default(uuid()) @map("_id")
  ownerId       String
  species       String
  tier          Int
  bond          Int      @default(0)
  passiveMode   String   @default("idle")
  statGaga      Int      @default(1)
  statGoz       Int      @default(1)
  statKulak     Int      @default(1)
  statKanat     Int      @default(1)
  statPence     Int      @default(1)
  quality       String   @default("Common")
  hp            Int
  hpMax         Int
  staminaCur    Int
  isMain        Boolean  @default(false)
  effectiveness Int      @default(100)
  createdAt     DateTime @default(now())
  traits        Json?

  owner Player @relation(fields: [ownerId], references: [id])

  // Main owl lookup index'i — her hunt/pvp/tame'de kullanılır
  @@index([ownerId, isMain])
  @@index([ownerId, passiveMode])
}

model InventoryItem {
  id       String @id @default(uuid()) @map("_id")
  ownerId  String
  itemName String
  itemType String
  rarity   String
  quantity Int    @default(1)

  owner Player @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, itemName])
  @@index([ownerId])
  @@index([ownerId, itemType])
}

model PvpSession {
  id           String   @id @default(uuid()) @map("_id")
  challengerId String
  defenderId   String
  status       String   @default("pending")
  winnerId     String?
  totalTurns   Int?
  createdAt    DateTime @default(now())
  finishedAt   DateTime?

  challenger Player @relation("Challenger", fields: [challengerId], references: [id])
  defender   Player @relation("Defender", fields: [defenderId], references: [id])

  @@index([challengerId])
  @@index([defenderId])
  @@index([status])
}

model Encounter {
  id           String   @id @default(uuid()) @map("_id")
  playerId     String
  owlSpecies   String
  owlTier      Int
  owlQuality   String
  owlStats     Json
  owlTraits    Json?
  tameAttempts Int      @default(0)
  failStreak   Int      @default(0)
  status       String   @default("open")
  createdAt    DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  // Limbo cleanup ve tame lookup için
  @@index([playerId, status])
  @@index([status, createdAt])
}

model PlayerRegistration {
  id          String   @id @default(uuid()) @map("_id")
  userId      String
  username    String
  displayName String?
  guildId     String
  guildName   String
  acceptedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player Player @relation(fields: [userId], references: [id])

  @@unique([userId, guildId])
  @@index([guildId])
}
