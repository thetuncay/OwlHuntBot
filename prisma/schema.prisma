generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id                 String   @id @default(uuid())
  coins              Int      @default(0)
  level              Int      @default(1)
  xp                 Int      @default(0)
  mainOwlId          String?
  lastHunt           DateTime?
  lastSwitch         DateTime?
  pvpStreak          Int      @default(0)
  pvpStreakLoss      Int      @default(0)
  gambleStreakWins   Int      @default(0)
  gambleStreakLosses Int      @default(0)
  huntComboStreak    Int      @default(0)
  pvpCount           Int      @default(0)
  switchPenaltyUntil DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // --- LIDERBOARD ISTATISTIKLERI ---
  totalHunts       Int      @default(0)
  totalRareFinds   Int      @default(0)
  totalPvpWins     Int      @default(0)
  totalCoinsEarned Int      @default(0)
  powerScore       Int      @default(0)
  totalXP          Int      @default(0)

  // --- PVP STREAK ---
  pvpBestStreak    Int      @default(0)

  // --- PITY SISTEMI ---
  noRareStreak     Int      @default(0)

  // --- BUFF & LOOTBOX SISTEMI ---
  dailyLootboxDrops   Int       @default(0)
  lastLootboxDropDate DateTime?

  // --- TRANSFER SİSTEMİ ---
  dailyTransferSent     Int       @default(0)
  dailyTransferReceived Int       @default(0)
  lastTransferDate      DateTime?

  // --- MARKET SİSTEMİ ---
  dailyMarketListings   Int       @default(0)
  lastMarketListingDate DateTime?

  // --- PRESTIGE SİSTEMİ ---
  prestigeLevel   Int @default(0)
  prestigePoints  Int @default(0)

  owls            Owl[]
  inventory       InventoryItem[]
  pvpAsChallenger PvpSession[]   @relation("Challenger")
  pvpAsDefender   PvpSession[]   @relation("Defender")
  encounters      Encounter[]
  registrations   PlayerRegistration[]
  seasonArchives  SeasonArchive[]
  activeBuffs     PlayerBuff[]
  marketListings  MarketListing[]
  dailyQuests     DailyQuest[]

  // Liderboard sıralama index'leri — full table scan'i önler
  @@index([powerScore])
  @@index([totalHunts])
  @@index([totalRareFinds])
  @@index([totalPvpWins])
  @@index([totalCoinsEarned])
  @@index([totalXP])
}

// Aktif buff kayitlari — oyuncunun kullandigı geçici buff'lar
model PlayerBuff {
  id          String   @id @default(uuid())
  playerId    String
  buffItemId  String
  category    String
  effectType  String
  effectValue Float
  chargeMax   Int
  chargeCur   Int
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, category])
  @@index([playerId, effectType])
  // Aktif buff sorgusu için (chargeCur > 0 filtresi)
  @@index([playerId, category, chargeCur])
}

// Sezon kayitlari — her sezon sonunda anlık snapshot
model SeasonArchive {
  id             String   @id @default(uuid())
  playerId       String
  seasonId       String   // "2026-W16" veya "2026-04" formatinda
  seasonType     String   // "weekly" | "monthly"
  powerScore     Int      @default(0)
  totalHunts     Int      @default(0)
  totalRareFinds Int      @default(0)
  totalPvpWins   Int      @default(0)
  totalCoinsEarned Int    @default(0)
  rank           Int      @default(0)   // O sezon sonu sirasi
  archivedAt     DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  @@index([seasonId])
  @@index([playerId])
}

// Aktif sezon bilgisi (tek kayit, upsert ile guncellenir)
model Season {
  id         String   @id @default(uuid())
  seasonId   String                      // "2026-W16"
  seasonType String                      // "weekly" | "monthly"
  startedAt  DateTime @default(now())
  endsAt     DateTime
}

model Owl {
  id            String   @id @default(uuid())
  ownerId       String
  species       String
  tier          Int
  bond          Int      @default(0)
  passiveMode   String   @default("idle")
  statGaga      Int      @default(1)
  statGoz       Int      @default(1)
  statKulak     Int      @default(1)
  statKanat     Int      @default(1)
  statPence     Int      @default(1)
  quality       String   @default("Common")
  hp            Int
  hpMax         Int
  staminaCur    Int
  isMain        Boolean  @default(false)
  effectiveness Int      @default(100)
  createdAt     DateTime @default(now())
  traits        Json?

  owner Player @relation(fields: [ownerId], references: [id])

  // Main owl lookup index'i — her hunt/pvp/tame'de kullanılır
  @@index([ownerId, isMain])
  @@index([ownerId, passiveMode])
}

model InventoryItem {
  id       String @id @default(uuid())
  ownerId  String
  itemName String
  itemType String
  rarity   String
  quantity Int    @default(1)

  owner Player @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, itemName])
  @@index([ownerId])
  @@index([ownerId, itemType])
}

model PvpSession {
  id           String   @id @default(uuid())
  challengerId String
  defenderId   String
  status       String   @default("pending")
  winnerId     String?
  totalTurns   Int?
  createdAt    DateTime @default(now())
  finishedAt   DateTime?

  challenger Player @relation("Challenger", fields: [challengerId], references: [id])
  defender   Player @relation("Defender", fields: [defenderId], references: [id])

  @@index([challengerId])
  @@index([defenderId])
  @@index([status])
}

model Encounter {
  id           String   @id @default(uuid())
  playerId     String
  owlSpecies   String
  owlTier      Int
  owlQuality   String
  owlStats     Json
  owlTraits    Json?
  tameAttempts Int      @default(0)
  failStreak   Int      @default(0)
  status       String   @default("open")
  createdAt    DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])

  // Limbo cleanup ve tame lookup için
  @@index([playerId, status])
  @@index([status, createdAt])
}

model PlayerRegistration {
  id          String   @id @default(uuid())
  userId      String
  username    String
  displayName String?
  guildId     String
  guildName   String
  acceptedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player Player @relation(fields: [userId], references: [id])

  @@unique([userId, guildId])
  @@index([guildId])
}

model MarketListing {
  id              String    @id @default(uuid())
  listingNo       Int       @unique @default(autoincrement())
  sellerId        String
  itemId          String
  itemName        String
  itemType        String
  marketCategory  String    // owl | item | buff | material
  rarity          String
  quantity        Int
  price           Int
  listingFeePaid  Int       @default(0)
  status          String    @default("active") // active | reserved | sold | expired | cancelled | returned
  buyerId         String?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  soldAt          DateTime?

  seller Player @relation(fields: [sellerId], references: [id])

  @@index([itemName])
  @@index([itemId])
  @@index([sellerId, status])
  @@index([status, expiresAt])
  @@index([marketCategory, status])
}

model MarketSale {
  id             Int      @id @default(autoincrement())
  listingId      String
  listingNo      Int
  sellerId       String
  buyerId        String
  itemId         String
  itemName       String
  itemType       String
  marketCategory String
  quantity       Int
  salePrice      Int
  taxPaid        Int
  riskScore      Int      @default(0)
  soldAt         DateTime @default(now())

  @@index([itemId])
  @@index([itemName])
  @@index([sellerId, buyerId])
  @@index([soldAt])
}

model MarketAnalytics {
  itemId            String   @id
  itemName          String
  lastSalePrice     Int      @default(0)
  averagePrice24h   Int      @default(0)
  averagePrice7d    Int      @default(0)
  medianPrice30d    Int      @default(0)
  salesCount24h     Int      @default(0)
  salesCount7d      Int      @default(0)
  updatedAt         DateTime @updatedAt

  @@index([itemName])
}

model MarketSuspiciousLog {
  id          Int      @id @default(autoincrement())
  saleId      Int?
  listingId   String?
  sellerId    String
  buyerId     String
  itemId      String
  itemName    String
  salePrice   Int
  riskScore   Int
  riskFactors Json
  createdAt   DateTime @default(now())

  @@index([riskScore])
  @@index([sellerId, buyerId])
  @@index([createdAt])
}

model DailyQuest {
  id          String   @id @default(uuid())
  playerId    String
  type        String // hunt, craft, tame, market
  target      Int
  current     Int      @default(0)
  rewardCoins Int
  rewardXp    Int
  isClaimed   Boolean  @default(false)
  resetAt     DateTime

  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId])
}

model AuditLog {
  id        String   @id @default(uuid())
  playerId  String
  action    String
  before    Json
  after     Json
  createdAt DateTime @default(now())

  @@index([playerId, createdAt])
}
