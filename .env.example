# ============================================================
# OwlHuntBot — Ortam Degiskenleri Ornegi
# Kopyala: cp .env.example .env
# ============================================================

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id
GUILD_ID=your_discord_guild_id

# Ortam: development | production | test
NODE_ENV=production

# PostgreSQL — PgBouncer uzerinden (transaction pooling)
# appendPoolParams port 6432 icin otomatik pgbouncer=true ekler (Prisma 42P05 fix)
DATABASE_URL="postgresql://postgres@localhost:6432/owlhuntbot"
# Migration / prisma db push icin direkt Postgres (opsiyonel)
# DIRECT_DATABASE_URL="postgresql://postgres@localhost:5432/owlhuntbot"

# Redis (hot state + BullMQ) — Docker port 6380
REDIS_URL=redis://localhost:6380

# Process modu (PM2 ecosystem otomatik ayarlar)
# RUN_MODE=bot
# RUN_MODE=worker

# DB pool (appendPoolParams ile URL'e eklenir)
BOT_DB_POOL_LIMIT=8
WORKER_DB_POOL_LIMIT=25
DB_POOL_TIMEOUT=10

# Yogunluk korumasi: ayni anda islenecek max komut (global)
MAX_CONCURRENT_COMMANDS=40
# Koruma sayaci TTL (saniye)
COMMAND_GATE_TTL_SECONDS=15
# BullMQ worker paralelligi (DB write throughput)
DB_QUEUE_CONCURRENCY=20
# Redis-first persist debounce (ms)
PERSIST_DEBOUNCE_MS=2500

# Saglik kontrolu portu (shard manager HTTP /health)
HEALTH_PORT=3010

# AI soru-cevap (opsiyonel — /owl soru komutu, kod GROQ kullanir)
GROQ_API_KEY=

# Liderboard Discord rolleri (opsiyonel — yoksa /admin ile otomatik olusturulur)
ROLE_POWER_1=
ROLE_POWER_2=
ROLE_HUNT_1=
ROLE_HUNT_2=
ROLE_HUNT_3=
ROLE_RELIC_1=
ROLE_RELIC_2=
ROLE_ARENA_1=
ROLE_ARENA_2=
ROLE_WEALTH_1=
ROLE_WEALTH_2=

# Migration scriptleri icin (opsiyonel)
MONGODB_URL=mongodb://localhost:27017/baykusbot
