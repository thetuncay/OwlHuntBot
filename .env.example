# ============================================================
# OwlHuntBot — Ortam Degiskenleri Ornegi
# Kopyala: cp .env.example .env
# ============================================================

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id
GUILD_ID=your_discord_guild_id

# Ortam: development | production | test
NODE_ENV=development

# PostgreSQL (Prisma)
# connection_limit: PM2 shard basina baglanti havuzu
# pool_timeout: havuz doluyken bekleme suresi (saniye)
DATABASE_URL=postgresql://postgres:password@localhost:5432/owlhuntbot?connection_limit=50&pool_timeout=15&connect_timeout=10

# Redis (cache, anti-spam, BullMQ kuyrugu)
REDIS_URL=redis://localhost:6379

# Saglik kontrolu portu (shard manager HTTP /health)
# 3000 baska PM2 uygulamalari tarafindan kullaniliyorsa 3010 secin
HEALTH_PORT=3010

# AI soru-cevap (opsiyonel — /owl soru komutu)
GROQ_API_KEY=

# Liderboard Discord rolleri (opsiyonel — yoksa /admin ile otomatik olusturulur)
ROLE_POWER_1=
ROLE_POWER_2=
ROLE_HUNT_1=
ROLE_HUNT_2=
ROLE_HUNT_3=
ROLE_RELIC_1=
ROLE_RELIC_2=
ROLE_ARENA_1=
ROLE_ARENA_2=
ROLE_WEALTH_1=
ROLE_WEALTH_2=

# Migration scriptleri icin (opsiyonel)
MONGODB_URL=mongodb://localhost:27017/baykusbot
